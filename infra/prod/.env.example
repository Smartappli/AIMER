# Non-secret production variable inventory. Store real values in a secret manager.

ENVIRONMENT=production
DJANGO_ENVIRONMENT=production
AIMER_RAG_ENVIRONMENT=production
MAGE_ENVIRONMENT=production
FARM_FEDERATED_ENVIRONMENT=production
DEBUG=false
DJANGO_DEBUG=false

BASE_URL=https://aimer.example.org
DJANGO_BASE_URL=https://farm.example.org
ALLOWED_HOSTS=aimer.example.org
DJANGO_ALLOWED_HOSTS=farm.example.org
CSRF_TRUSTED_ORIGINS=https://aimer.example.org

SECRET_KEY=<vault:aimer-web-secret-key>
DJANGO_SECRET_KEY=<vault:farm-secret-key>
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/aimer_web?sslmode=require
DJANGO_DATABASE_URL=postgresql://<user>:<password>@<host>:5432/farm?sslmode=require

SECURE_SSL_REDIRECT=true
DJANGO_SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
DJANGO_SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_SECONDS=31536000

EMAIL_HOST=smtp.example.org
EMAIL_PORT=587
EMAIL_HOST_USER=<vault:smtp-user>
EMAIL_HOST_PASSWORD=<vault:smtp-password>
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@example.org
EMAIL_VERIFICATION_REQUIRED=true

RAG_SERVICE_URL=https://aimer-rag.internal:8000
RAG_SERVICE_API_KEY=<vault:rag-service-api-key>
RAG_SERVICE_CA_CERT_PATH=/etc/aimer-rag-ca/ca.crt
AIMER_RAG_API_KEY=<vault:rag-service-api-key>
MAGE_API_KEY=<vault:mage-api-key>

OPENRAG_ENDPOINT=https://openrag.example.org
OPENRAG_API_KEY=<vault:openrag-api-key>
QDRANT_URL=https://qdrant.example.org
QDRANT_API_KEY=<vault:qdrant-api-key>
RAG_STRICT_OPENRAG=true
RAG_ALLOW_UNGROUNDED_RECOMMENDATIONS=false
RAG_ALLOW_EXTERNAL_PLUGINS=false

AUTH_LOGIN_FAILURE_LIMIT=5
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_EMAIL_ACTION_LIMIT=5
AUTH_EMAIL_ACTION_WINDOW_SECONDS=3600
SECURITY_AUDIT_LOG_LEVEL=INFO
